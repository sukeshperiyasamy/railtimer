generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Train {
  id            String   @id @default(cuid())
  trainNumber   String   @unique
  trainName     String
  slug          String   @unique
  sourceStation String
  destStation   String
  runsOn        String[] // days of week
  // Trigram GIN indexes on trainName/trainNumber for fast ILIKE '%...%'
  // search at 5,000+ rows exist in the DB (migration
  // 20260720071439_add_pg_trgm_trainname_index) but aren't representable
  // here without the postgresqlExtensions preview feature — don't run
  // `prisma db push` or `migrate reset` against this schema, as either
  // would drop them since they're "unmanaged" from schema.prisma's view.
  // Denormalized summary fields for fast list/sitemap rendering without a
  // Stop join — source of truth remains the Stop rows; keep these in sync
  // when stops change. Nullable so backfilling is non-breaking.
  departureTime String? // source station departure, e.g. "16:25"
  arrivalTime   String? // destination station arrival, e.g. "08:35"
  duration      String? // total journey time, e.g. "16h 10m"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  stops         Stop[]

  @@index([sourceStation, destStation])
}

model Stop {
  id            String   @id @default(cuid())
  train         Train    @relation(fields: [trainId], references: [id], onDelete: Cascade)
  trainId       String
  stationCode   String
  stationName   String
  station       Station? @relation(fields: [stationId], references: [id])
  stationId     String?
  arrivalTime   String?
  departureTime String?
  dayNumber     Int
  sequence      Int

  @@index([trainId])
  @@index([stationCode])
  @@index([stationId])
}

/// Additive station registry (code/name/state/coordinates) for future
/// station pages. Stop.stationCode/stationName remain the source of truth
/// for schedule rendering — Station is an optional enrichment, linked via
/// Stop.stationId once populated.
model Station {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  state     String?
  latitude  Float?
  longitude Float?
  stops     Stop[]

  @@index([code])
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  content     String
  publishedAt DateTime @default(now())
}
