# Supabase Postgres — pooled connection (PgBouncer), used at runtime
DATABASE_URL=

# Supabase Postgres — direct connection, used only for Prisma migrations
DIRECT_URL=

# Supabase project
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis (serverless REST API)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Unofficial rail-data API — no key configured yet, RailDataProvider falls
# back to a mock implementation until these are set (see lib/rail-data-provider.ts)
RAIL_DATA_API_KEY=
RAIL_DATA_API_BASE_URL=

# Analytics / SEO / Ads
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
